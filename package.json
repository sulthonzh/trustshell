{
  "name": "trustshell",
  "version": "1.0.1",
  "description": "Zero-dependency CLI tool for verifying AI-generated code quality and functionality",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "trustshell": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "npm run build && node --test test/*.test.ts",
    "test:coverage": "npm run build && c8 node --test test/*.test.ts",
    "test:watch": "npm run build && node --test --watch test/*.test.ts",
    "lint": "eslint src",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "verification",
    "code-quality",
    "testing",
    "cli",
    "trust",
    "ai-generated",
    "code-analysis"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "ts-node": "^10.9.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
